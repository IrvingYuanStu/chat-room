{
  "name": "chat-room",
  "version": "0.1.0",
  "type": "module",
  "description": "P2P chat room tool for macOS terminal with ZooKeeper node discovery",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "chat-room": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src/",
    "package": "npm run build && pkg .",
    "package:macos": "npm run build && pkg . --targets node18-macos-x64 --output ./binaries/chat-room-macos",
    "package:linux": "npm run build && pkg . --targets node18-linux-x64 --output ./binaries/chat-room-linux",
    "package:win": "npm run build && pkg . --targets node18-win-x64 --output ./binaries/chat-room-win.exe"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chalk": "^5.6.2",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "node-zookeeper-client": "^1.1.3",
    "react": "^18.3.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/node-zookeeper-client": "^1.1.0",
    "@types/react": "^18.3.28",
    "@types/uuid": "^10.0.0",
    "pkg": "^5.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
